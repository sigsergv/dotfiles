// Zed settings
//
// Copy/symlink this file to ~/.config/zed/settings.json
//
// Origin: https://github.com/sigsergv/dotfiles/blob/master/zed/settings.json
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_whitespaces": "boundary",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "tabs": {
    "show_close_button": "hidden",
  },
  "buffer_line_height": {
    "custom": 1.2,
  },
  "format_on_save": "off",
  "buffer_font_family": "Liberation Mono",
  "agent_ui_font_size": 14.0,
  "ui_font_family": "PT Sans",
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 15.0,
  "buffer_font_size": 11.0,
  "theme": {
    "mode": "light",
    "light": "One Light",
    "dark": "One Dark",
  },
  "wrap_guides": [80,100],
  "show_wrap_guides": true,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
}
