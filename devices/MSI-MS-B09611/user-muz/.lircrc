begin
  prog = irexec
  button = KEY_PLAYPAUSE
  config = /home/muz/bin/play-pause
#  config = xte 'key XF86AudioPlay'
end

begin
  prog = irexec
  button = KNOB_MUTE
  config = /home/muz/bin/play-pause
end

begin
  prog = irexec
  button = KEY_NEXT
  config = xte 'key XF86AudioNext'
end

begin
  prog = irexec
  button = KEY_PREVIOUS
  config = xte 'key XF86AudioPrev'
end

begin
  prog = irexec
  button = KNOB_VOLUMEUP
  repeat = 1
  config = /home/muz/bin/volume_up
end

begin
  prog = irexec
  button = KNOB_VOLUMEDOWN
  repeat = 1
  config = /home/muz/bin/volume_down
end

begin
  prog = irexec
  button = KEY_VOLUMEUP
  repeat = 1
  config = /home/muz/bin/volume_up
end

begin
  prog = irexec
  button = KEY_VOLUMEDOWN
  repeat = 1
  config = /home/muz/bin/volume_down
end
